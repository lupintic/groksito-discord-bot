# =============================================================================
# Groksito Discord Bot — Archivo de Configuración (.env)
# =============================================================================
#
# INSTRUCCIONES:
#   1. Copia este archivo como `.env`  (o ejecuta `python setup.py`)
#   2. Completa al menos DISCORD_BOT_TOKEN y la autenticación de xAI.
#   3. Usa `python setup.py` para una experiencia guiada y segura (recomendado).
#
# Este es el template oficial y limpio. Todas las claves están en UPPER_SNAKE_CASE.
# El bot (pydantic-settings) y el escritor seguro de .env tratan las claves como
# case-insensitive, por lo que respeta el casing original de tu archivo actual.
#
# Filosofía del bot:
#   - "Let Grok be Grok": mínima inyección de contexto, confiar en las capacidades
#     nativas de Grok (contexto largo, web_search, vision, personalidad).
#   - Los secretos solo viven en .env o en el archivo de tokens OAuth (nunca en git).
#   - El dashboard web (/config) SOLO puede editar ajustes seguros (nunca tokens).
#
# Requeridos para que el bot arranque:
#   - DISCORD_BOT_TOKEN
#   - Autenticación xAI: XAI_API_KEY (estable)  O  login OAuth (experimental)
#
# Altamente recomendado:
#   - ALLOWED_GUILD_IDS (lista blanca de servidores por seguridad)
#   - GROK_AUTH_MODE (explícito)
#
# =============================================================================

# -----------------------------------------------------------------------------
# DISCORD (REQUERIDO)
# -----------------------------------------------------------------------------
# Token del bot. Obtenlo en: https://discord.com/developers/applications
# (Bot > Token > Reset Token si es necesario)
DISCORD_BOT_TOKEN=

# Lista blanca de Guild IDs (servidores). Muy recomendado en producción.
# Formato: lista separada por comas O array JSON compacto.
# Ejemplos:
#   ALLOWED_GUILD_IDS=123456789012345678,987654321098765432
#   ALLOWED_GUILD_IDS=[123456789012345678,987654321098765432]
# Vacío = el bot aceptará invitaciones y funcionará en CUALQUIER servidor
# (no recomendado por seguridad).
ALLOWED_GUILD_IDS=

# -----------------------------------------------------------------------------
# AUTENTICACIÓN xAI / GROK
# -----------------------------------------------------------------------------
# --- Opción recomendada (estable): API Key clásica ---
# Consigue tu key en https://console.x.ai
XAI_API_KEY=

# Modo de autenticación:
#   api_key  → siempre usa XAI_API_KEY (recomendado para la mayoría, estable)
#   oauth    → obliga a usar OAuth de navegador (SuperGrok / X Premium+). No necesita XAI_API_KEY.
#   auto     → prefiere token OAuth válido si existe (con refresh), cae a XAI_API_KEY si no.
#              Mejor UX: haces login una vez y casi lo olvidas.
GROK_AUTH_MODE=api_key

# --- OAuth experimental (SuperGrok / X Premium+) ---
# Flujo de navegador OAuth 2.0 + PKCE contra accounts.x.ai (igual que Hermes Agent).
# Después de poner GROK_AUTH_MODE=oauth o auto, ejecuta una vez:
#     python -m src.groksito_discord --login-oauth
#     (o responde "sí" cuando setup.py te lo ofrezca)
#
# Documentación completa (SSH tunnel, Docker, --no-browser, --print-url-only,
# solución de 403/tier, invalid_grant, puertos, etc.):
#   Ver GROK_OAUTH.md
#
# Los tokens reales se guardan en ./oauth/xai_oauth_tokens.json (NUNCA en .env).
# Puedes cambiar la ubicación si quieres:
# GROK_OAUTH_PORT=56121
# GROK_OAUTH_TOKEN_FILE=./oauth/xai_oauth_tokens.json

# -----------------------------------------------------------------------------
# MODELO Y COMPORTAMIENTO DE API
# -----------------------------------------------------------------------------
GROK_MODEL=grok-4.3

# Reintentos solo para errores transitorios (429, 5xx, red). Los errores de auth/policy fallan ya.
API_MAX_RETRIES=3
API_RETRY_BASE_DELAY_SECONDS=0.5
API_TIMEOUT_SECONDS=60.0
# La generación de video usa un presupuesto interno más largo (~300s).

# -----------------------------------------------------------------------------
# FEATURE FLAGS
# -----------------------------------------------------------------------------
# Generación de video (Text-to-Video + Image-to-Video explícito).
# Pon false para control de costos o durante incidentes.
ENABLE_VIDEO_GENERATION=true

# -----------------------------------------------------------------------------
# CONTEXTO RECIENTE (resumen ligero y de alta señal)
# -----------------------------------------------------------------------------
# Cuando mencionan al bot o le responden, genera un resumen corto y de calidad
# de los mensajes recientes del canal y lo inyecta. Separado del "proactive summarization".
ENABLE_RECENT_CONTEXT_SUMMARY=true
ENABLE_RECENT_CONTEXT=true          # alias legacy (preferir el de arriba)
RECENT_CONTEXT_MESSAGE_LIMIT=20
RECENT_CONTEXT_MAX_TOKENS=400

# -----------------------------------------------------------------------------
# SUMARIZACIÓN PROACTIVA (compactación de historial antiguo)
# -----------------------------------------------------------------------------
# Deshabilitado por defecto. El contexto nativo de Grok es muy grande.
# Solo activar si ves consumo excesivo de tokens en hilos muy largos.
SUMMARIZATION_ENABLED=false
SUMMARIZATION_THRESHOLD_TOKENS=6000

# -----------------------------------------------------------------------------
# AJUSTES DE CONTEXTO Y CONVERSACIÓN
# -----------------------------------------------------------------------------
# Tiering dinámico de contexto: inyección ligera en consultas simples,
# más rica cuando la conversación es compleja. Muy recomendado.
CONTEXT_SMART_MODE=true

# En rondas de continuación con tools, envía la lista de tools más pequeña posible.
# Uno de los mayores ahorradores de tokens. Déjalo activado.
AGGRESSIVE_CONTINUATION_TOOL_MINIMIZATION=true

# Logs estructurados de decisión de tools y efectividad de caché (bajo overhead).
LOG_TOOL_SELECTION=true
LOG_CACHE_METRICS=true

# -----------------------------------------------------------------------------
# TTS / AUDIO (xAI /v1/tts)
# -----------------------------------------------------------------------------
# Voz y lenguaje por defecto para la herramienta de voz/TTS.
# Voces disponibles: eve (predeterminada, enérgica), ara, rex, sal, leo
# Lenguaje: código BCP-47. 'es' funciona bien para español, 'en' para inglés, 'auto' para mixto.
# El parámetro de lenguaje es OBLIGATORIO para el endpoint TTS de xAI.
TTS_DEFAULT_VOICE=eve
TTS_DEFAULT_LANGUAGE=es

# -----------------------------------------------------------------------------
# LÍMITES Y UMBRALES (se pueden cambiar desde el dashboard web)
# -----------------------------------------------------------------------------
# The following thresholds (and several others) are exposed for live editing via the web dashboard (/config).
# They are defined with full comments in the sections above. Do not duplicate values here.
# Examples of web-editable ones:
#   RECENT_CONTEXT_MESSAGE_LIMIT, RECENT_CONTEXT_MAX_TOKENS, SUMMARIZATION_THRESHOLD_TOKENS,
#   API_MAX_RETRIES, RECENT_CONTEXT_MESSAGE_LIMIT, etc.
# After web edits, restart the Discord bot process for changes to take effect.

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
# INFO es lo recomendado para producción. DEBUG es ruidoso pero útil al desarrollar.
LOG_LEVEL=INFO

# -----------------------------------------------------------------------------
# PERSISTENCIA
# -----------------------------------------------------------------------------
# Contexto de canal de corto plazo (estado de conversación).
DATA_DIR=./data
# PANTSU_CONTEXT_FILE=   # (opcional, override legacy)

# -----------------------------------------------------------------------------
# NOTAS IMPORTANTES
# -----------------------------------------------------------------------------
# - Todas las claves son case-insensitive en tiempo de ejecución (pydantic-settings).
# - El escritor seguro (usado por setup.py y el web UI):
#     * Actualiza claves existentes in-place (búsqueda case-insensitive, preserva casing original)
#     * Colapsa duplicados pre-existentes de la clave que estás tocando
#     * Solo agrega claves completamente nuevas
#     * Siempre hace backup antes + escritura atómica + verificación de críticos
# - Usa SIEMPRE `python setup.py` para crear/reparar .env (especialmente secretos).
# - Después de cambiar algo desde el dashboard web, reinicia el proceso del bot de Discord.
#
# Para la guía completa de OAuth (altamente recomendada si quieres probar sin API key):
#   Ver GROK_OAUTH.md
#
# Comandos útiles después de setup:
#   python -m src.groksito_discord --status
#   python -m src.groksito_discord --check
#   python -m src.groksito_discord --login-oauth
#
# =============================================================================
